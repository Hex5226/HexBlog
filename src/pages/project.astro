---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import ProjectCard from "@/components/mdx/ProjectCard.astro";

// 定义项目类型（可选，如果将来添加项目时使用）
interface Project {
  name: string;
  avatar: string;
  description: string;
  url: string;
  badge: string;
}

const projects: Project[] = [];   // 显式声明为空数组，类型为 Project[]
---

<BaseLayout title="Projects" isIndexed={false}>
  <div class="mb-8 animate-fade-in-up">
    <h1 class="text-3xl md:text-4xl font-bold mb-4 flex items-center gap-3">
      <Icon name="lucide:folder-git-2" class="text-primary" />
      <span>My Projects</span>
    </h1>
    <p class="text-base-content/70 text-lg">
      这里将展示我的个人项目，敬请期待。
    </p>
  </div>

  {projects.length === 0 ? (
    <div class="text-center py-12 text-base-content/60">
      <Icon name="lucide:folder-open" class="w-16 h-16 mx-auto mb-4 opacity-50" />
      <p>暂无项目，正在筹备中...</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in-up" style="animation-delay: 0.1s;">
      {projects.map((project) => (
        <ProjectCard
          name={project.name}
          avatar={project.avatar}
          description={project.description}
          url={project.url}
          badge={project.badge}
        />
      ))}
    </div>
  )}

<div class="flex justify-center mt-12 animate-fade-in-up" style="animation-delay: 0.2s;">
    <a
      href="https://github.com/Hex5226?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary btn-outline gap-2 px-8"
    >
      <Icon name="lucide:github" class="w-5 h-5" />
      <span>View More on GitHub</span>
    </a>
  </div>

  <div class="divider my-6 animate-fade-in-up" style="animation-delay: 0.1s;">
    <Icon name="lucide:heart" class="w-12 h-12 text-primary/50" />
  </div>
</BaseLayout>